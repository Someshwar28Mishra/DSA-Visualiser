# ── Frontend origin (for CORS) ────────────────────────────────────────────────
# Copy this file to .env and fill in your values.

# Local development:
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Production (Vercel) — replace with your actual Vercel domain:
# CORS_ORIGINS=https://your-app.vercel.app

# Multiple origins (comma-separated):
# CORS_ORIGINS=https://your-app.vercel.app,https://your-custom-domain.com

# Optional — regex to match ALL Vercel preview deploy URLs automatically.
# Default (already built-in): https://.*\.vercel\.app
# CORS_ORIGIN_REGEX=https://your-app-.*\.vercel\.app
