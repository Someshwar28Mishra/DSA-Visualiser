# ─── Python bytecode ──────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd

# ─── Virtual environments ─────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/
.env/
virtualenv/

# ─── Environment variables ────────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.env

# ─── Distribution / packaging ─────────────────────────────────────────────────
dist/
build/
*.egg-info/
*.egg
MANIFEST
.eggs/

# ─── Installer logs ───────────────────────────────────────────────────────────
pip-log.txt
pip-delete-this-directory.txt

